# Shuffle Partey configuration overrides
# Copy to .env and edit as needed: cp .env.example .env

# How long each DJ gets to play, in seconds (default: 900 = 15 minutes)
# SET_DURATION_SECONDS=900

# How long the audio crossfade takes, in seconds
# FADE_DURATION_SECONDS=3.0

# How long the visual crossfade between timer and logo takes, in seconds
# CROSSFADE_DURATION_SECONDS=3.0

# Mixer backend: "osc" (WiFi/Ethernet) or "midi" (USB-MIDI DIN adapter)
# MIXER_BACKEND=osc

# OSC backend: IP address and port of the XR12 on your network
# XR12_HOST=192.168.1.100
# XR12_PORT=10024

# MIDI backend: USB-MIDI adapter port name (auto-detect if empty, skips X-TOUCH ports)
# MIDI_MIXER_PORT=

# Stereo pair: which mixer channels (1–12) the DJ left/right audio is plugged into
# DJ_CHANNEL_L=1
# DJ_CHANNEL_R=2

# Stereo pair: which mixer channels the Pi's audio output (shuffle tracks) is plugged into
# SHUFFLE_CHANNEL_L=3
# SHUFFLE_CHANNEL_R=4

# MIDI controller port names (auto-detect if empty)
# MIDI_PORT=X-TOUCH ONE
# MIDI_EXTENDER_PORT=X-TOUCH-EXT

# Web-based remote display (open http://<host>:8080 in a browser on another device)
# WEB_DISPLAY_ENABLED=false
# WEB_DISPLAY_PORT=8080

# Directory containing the shuffle transition MP3s
# TRACKS_DIR=./tracks/
